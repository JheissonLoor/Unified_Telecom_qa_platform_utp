# Generado localmente por scripts/bootstrap.ps1 o bootstrap.sh.
# No confirmar .env. Estos nombres documentan el contrato, no contienen secretos.
APP_ENV=development
APP_BASE_URL=https://localhost
API_BASE_URL=https://localhost/api

POSTGRES_PASSWORD=REPLACE_ME
MIDPOINT_DB_PASSWORD=REPLACE_ME

JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
JWT_ACCESS_MINUTES=15
APP_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
PROVISIONING_TOKEN=REPLACE_ME

DEMO_AGENT_PASSWORD=REPLACE_ME
DEMO_AGENT2_PASSWORD=REPLACE_ME
DEMO_SUPERVISOR_PASSWORD=REPLACE_ME
DEMO_ADMIN_PASSWORD=REPLACE_ME

SIP_1001_SECRET=REPLACE_ME
SIP_1002_SECRET=REPLACE_ME
WEBRTC_2001_SECRET=REPLACE_ME
WEBRTC_2002_SECRET=REPLACE_ME

MIDPOINT_ADMIN_USER=administrator
MIDPOINT_ADMIN_PASSWORD=REPLACE_ME
SONAR_ADMIN_PASSWORD=REPLACE_ME

TURN_REALM=localhost
TURN_USER=webrtc
TURN_PASSWORD=REPLACE_ME
ASTERISK_VERSION=22.10.0

# Puertos host. Cambiarlos permite ejecutar otro laboratorio en paralelo.
HOST_HTTP_PORT=80
HOST_HTTPS_PORT=443
HOST_SIP_UDP_PORT=5060
HOST_SIP_TLS_PORT=5061
HOST_RTP_START=10000
HOST_RTP_END=10100
# Opcional para softphones en la misma LAN. Ejecutar configure_mobile_lab.ps1.
ASTERISK_EXTERNAL_ADDRESS=
ASTERISK_LOCAL_NET=
HOST_TURN_PORT=3478
HOST_TURN_TLS_PORT=5349
HOST_TURN_RELAY_START=49160
HOST_TURN_RELAY_END=49200
HOST_MIDPOINT_PORT=8080
HOST_SONAR_PORT=9000
